# FrameMatch · Variables de entorno (ejemplo)
#
# Copia este archivo a `.env` y rellena los valores reales.
# Los secrets (Google, Facebook) NUNCA se commitean.

# ─── App ──────────────────────────────────────────────────────────
APP_NAME=FrameMatch
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=UTC

# ─── Base de datos (XAMPP MySQL en dev / Railway en prod) ──────────
# Entorno local: configura DB_HOST, DB_PORT, DB_DATABASE, DB_USERNAME, DB_PASSWORD.
# Entorno Railway: NO configures DB_HOST aquí. Railway inyecta automáticamente
#   DB_URL=${{MySQL.MYSQL_URL}} desde el plugin MySQL del mismo proyecto.
#   Las variables DB_HOST/PORT/DATABASE/USERNAME/PASSWORD se ignoran en Railway.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=prueba_tecnica_daniel_castro
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache / sesión / cola ───────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=array
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
BCRYPT_ROUNDS=12

# ─── JWT (php-open-source-saver/jwt-auth) ──────────────────────────
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=60
JWT_REFRESH_TTL=20160

# ─── Frontend ─────────────────────────────────────────────────────
# URL del SPA Angular. Se usa para construir el redirect del callback OAuth.
FRONTEND_URL="http://localhost:4200"

# ─── OAuth · Google (Fase 5.3) ──────────────────────────────────
# Crear app en https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorized redirect URIs: ${APP_URL}/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/oauth/google/callback"

# ─── OAuth · Facebook (Fase 5.3) ────────────────────────────────
# Crear app en https://developers.facebook.com/ → My Apps
# Valid OAuth Redirect URIs: ${APP_URL}/api/auth/oauth/facebook/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/api/auth/oauth/facebook/callback"

# ─── Cloudinary (Fase 5.5 · Subida de imágenes) ──────────────────
# Cuenta en https://cloudinary.com/console. Los secrets NUNCA se commitean.
# 4 unsigned upload presets deben estar creados en el dashboard:
#   fm_av_upl  → folder: framematch/avatars     → max 2 MB  → jpg/jpeg/png/webp
#   fm_cv_upl  → folder: framematch/covers      → max 5 MB  → jpg/jpeg/png/webp
#   fm_pf_upl  → folder: framematch/portfolios  → max 8 MB  → jpg/jpeg/png/webp/gif
#   fm_br_upl  → folder: framematch/briefs      → max 5 MB  → jpg/jpeg/png/webp/gif
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_PRESET_AVATAR=fm_av_upl
CLOUDINARY_PRESET_COVER=fm_cv_upl
CLOUDINARY_PRESET_PORTFOLIO=fm_pf_upl
CLOUDINARY_PRESET_BRIEF=fm_br_upl
